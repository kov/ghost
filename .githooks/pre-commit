#!/bin/sh
# Pre-commit checks for ghost. To enable in this clone:
#   git config core.hooksPath .githooks
#
# Formatting covers the whole workspace, including the vendored avt fork in vt/
# (avt is fmt-clean upstream). Clippy is strict (-D warnings) on our crates
# across all targets, and on avt's LIBRARY only — the part we actually modify.
# avt's benches/tests are not linted: upstream runs no clippy and a bench trips
# a newer lint, so linting them would only cause rebase churn. avt's own gate is
# `cargo test`, run separately / in CI.

cargo fmt --all -- --check || {
    echo "cargo fmt found issues; run 'cargo fmt --all' to fix" >&2
    exit 1
}

cargo clippy --workspace --exclude avt --all-targets -- -D warnings || {
    echo "cargo clippy found issues" >&2
    exit 1
}

cargo clippy -p avt --lib -- -D warnings || {
    echo "cargo clippy found issues in vt/ (avt lib)" >&2
    exit 1
}
