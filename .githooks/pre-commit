#!/bin/sh
# Pre-commit checks for ghost. To enable in this clone:
#   git config core.hooksPath .githooks
#
# Formatting and clippy cover the whole workspace, ghost-term included — it is
# ghost's owned terminal core now (a fork of asciinema's avt), linted like any
# of our crates. Clippy is strict: -D warnings across all targets.

cargo fmt --all -- --check || {
    echo "cargo fmt found issues; run 'cargo fmt --all' to fix" >&2
    exit 1
}

cargo clippy --workspace --all-targets -- -D warnings || {
    echo "cargo clippy found issues" >&2
    exit 1
}
